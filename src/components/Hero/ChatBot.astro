---
import { languages, defaultLang, type Language } from '../../i18n';

// Import the image (it will be provided by the user)
// import chatBoxImg from '../../assets/images/cuadro_de_texto.png';
---

<div class="chatbot-container">
  <div class="terminal-input-row">
    <input type="text" id="chat-input" placeholder="..." autocomplete="off" />
  </div>

  <div id="chat-response-container" class="hidden">
    <!-- The user will provide cuadro_de_texto.png -->
    <div class="chat-box">
      <p id="chat-response-text"></p>
    </div>
  </div>
</div>

<style>
  .chatbot-container {
    margin-top: 1.5rem;
    width: 100%;
    font-family: var(--font-terminal);
  }

  .terminal-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid var(--color-matrix-primary);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    box-shadow: 0 0 10px rgba(57, 255, 20, 0.2);
  }

  .prompt {
    color: var(--color-matrix-primary);
    white-space: nowrap;
  }

  #chat-input {
    background: transparent;
    border: none;
    color: #fff;
    font-family: inherit;
    font-size: 1.1rem;
    width: 100%;
    outline: none;
    caret-color: var(--color-matrix-primary);
  }

  /* Response Box - Now positioned relative to the profile column */
  #chat-response-container {
    position: absolute;
    top: 20px; /* Near the top of the image (head level) */
    left: calc(100% + 20px); /* To the right of the image */
    width: 280px;
    z-index: 1000;
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  #chat-response-container.hidden {
    opacity: 0;
    transform: scale(0.8) translateY(20px);
    pointer-events: none;
  }

  .chat-box {
    position: relative;
    padding: 1.5rem;
    background: rgba(13, 13, 13, 0.95);
    border: 2px solid var(--color-matrix-primary);
    border-radius: 12px;
    box-shadow: 0 0 20px rgba(57, 255, 20, 0.4);
    color: var(--color-matrix-primary);
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(5px);
  }

  /* Speech bubble tail (pointing to the image) */
  .chat-box::after {
    content: '';
    position: absolute;
    left: -20px;
    top: 50%;
    transform: translateY(-50%);
    border-width: 10px 20px 10px 0;
    border-style: solid;
    border-color: transparent var(--color-matrix-primary) transparent transparent;
  }

  .chat-box::before {
    content: '';
    position: absolute;
    left: -17px;
    top: 50%;
    transform: translateY(-50%);
    border-width: 9px 18px 9px 0;
    border-style: solid;
    border-color: transparent rgba(13, 13, 13, 0.95) transparent transparent;
    z-index: 1;
  }

  #chat-response-text {
    margin: 0;
    font-size: 1.1rem;
    text-align: center;
    line-height: 1.4;
    text-shadow: 0 0 5px rgba(57, 255, 20, 0.5);
  }

  @media (max-width: 1200px) {
    #chat-response-container {
      left: 50%;
      top: 260px; /* Below the 250px mobile image */
      transform: translateX(-50%);
      width: 100%;
      max-width: 280px;
    }

    #chat-response-container.hidden {
      transform: translateX(-50%) scale(0.8) translateY(-20px);
    }

    .chat-box::after {
      left: 50%;
      top: -20px; /* Pointing UP */
      bottom: auto;
      transform: translateX(-50%);
      border-width: 0 10px 20px 10px;
      border-color: transparent transparent var(--color-matrix-primary) transparent;
    }

    .chat-box::before {
      left: 50%;
      top: -17px;
      bottom: auto;
      transform: translateX(-50%);
      border-width: 0 9px 18px 9px;
      border-color: transparent transparent rgba(13, 13, 13, 0.95) transparent;
    }
  }
</style>

<script>
  import { languages, defaultLang, type Language } from '../../i18n';

  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const responseContainer = document.getElementById('chat-response-container');
  const responseText = document.getElementById('chat-response-text');
  let responseTimeout: any;

  function getLang() {
    return (localStorage.getItem('language') as Language) || defaultLang;
  }

  async function handleChat(e: KeyboardEvent) {
    if (e.key === 'Enter' && chatInput.value.trim()) {
      const query = chatInput.value.toLowerCase().trim();
      const lang = getLang();
      const t = languages[lang].chatbot;
      
      const cleanQuery = query.replace(/[¿?¡!.,]/g, '').trim();
      
      const intents = [
        { key: 'greeting', keywords: ['hola', 'buenos dias', 'buenas tardes', 'buenas noches', 'saludos', 'hi', 'hello', 'hey', 'que tal', 'hablar', 'buen dia'] },
        { key: 'whoami', keywords: ['quien eres', 'quién eres', 'tu nombre', 'quien es pablo', 'quién es pablo', 'sobre ti', 'quien sos', 'biografia', 'quien es este'] },
        { key: 'skills', keywords: ['habilidades', 'que sabes hacer', 'qué sabes hacer', 'tus conocimientos', 'tu stack', 'tecnologias', 'programacion', 'redes cisco', 'python', 'java', 'javascript', 'mantenimiento pc', 'sabes de', 'skill', 'stacks', 'herramientas de programacion'] },
        { key: 'contact', keywords: ['contacto', 'email', 'correo', 'escribirte', 'tu linkedin', 'tu github', 'redes sociales', 'escribirle', 'contactame', 'hablar con pablo'] },
        { key: 'experience', keywords: ['experiencia', 'donde has trabajado', 'donde trabajas', 'tu trabajo', 'trayectoria laboral', 'mired ips', 'empresa', 'chamba', 'oficio', 'laburo'] },
        { key: 'certifications', keywords: ['certificados', 'estudios', 'educacion', 'cisco networking', 'ccna', 'tu titulo', 'formacion', 'universidad', 'estudiado', 'academico', 'diploma'] },
        { key: 'motto', keywords: ['tu lema', 'tu frase', 'filosofia', 'filosofía', 'motto', 'pensamiento', 'lema'] },
        { key: 'tools', keywords: ['herramientas', 'navaja suiza', 'victorinox', 'que llevas siempre', 'arquimedes', 'multiherramienta'] },
        { key: 'music', keywords: ['musica', 'qué música escuchas', 'playlist', 'melomano', 'rock', 'metal', 'jazz', 'lo que escuchas', 'audifonos'] },
        { key: 'bikes', keywords: ['motos', 'tu moto', 'dos ruedas', 'rodar', 'motocicleta', 'alto cilindraje', 'motero'] },
        { key: 'hates', keywords: ['que te molesta', 'que odias', 'sistemas mal hechos', 'eficiencia', 'rabia', 'disgusto'] },
        { key: 'family', keywords: ['tu familia', 'tus amigos', 'seres queridos', 'donde vive tu familia', 'con quien vives', 'padres', 'hermanos', 'lugar favorito', 'sitio favorito'] },
        { key: 'status', keywords: ['como estas', 'cómo estás', 'todo bien', 'como vas', 'qué haces', 'que haces', 'como andas', 'como va todo'] },
        { key: 'movies', keywords: ['peliculas', 'películas', 'cine', 'don\'t look up', 'bugonia', 'recomienda una peli', 'pelicula', 'película', 'que pelis ves', 'pelicula favorita', 'peli favorita'] },
        { key: 'food', keywords: ['comida favorita', 'que comes', 'que te gusta comer', 'hambre', 'carne con papas', 'comida', 'plato favorito', 'cenar', 'almorzar'] },
        { key: 'hobbies', keywords: ['hobbies', 'pasatiempos', 'que haces en tu tiempo libre', 'lol', 'minecraft', 'the binding of isaac', 'ejercicio', 'naturaleza', 'hobby', 'gaming', 'juegos', 'videojuegos', 'color favorito', 'que te gusta hacer', 'entrenar', 'viajar', 'animales', 'verde es mi color'] },
        { key: 'philosophy', keywords: ['navaja suiza', 'aprender', 'si no se lo aprendo', 'no puedo', 'tu especialidad', 'especial', 'aprender rapido'] },
        { key: 'goals', keywords: ['metas', 'objetivos', 'mejor zapatero', 'aspiraciones', 'futuro', 'donde te ves'] },
        { key: 'teamwork', keywords: ['trabajo en equipo', 'horizontal', 'liderazgo', 'sumision', 'colaborar', 'grupal'] },
        { key: 'location', keywords: ['donde eres', 'de donde vienes', 'donde vives', 'donde estas', 'ubicacion', 'arauca', 'barranquilla', 'resides', 'procedencia', 'ubicación', 'donde estas basado'] },
        { key: 'failure', keywords: ['fracaso', 'aprendizaje', 'errores', 'fallar', 'perder', 'equivocarse'] },
        { key: 'favTech', keywords: ['python en mi bota', 'toy story', 'serpiente', 'python en la bota'] },
        { key: 'joke', keywords: ['chiste', 'algo gracioso', 'broma', 'risas'] }
      ];

      let bestMatch = { key: 'default', score: 0 };

      // Improved Scoring logic v2
      intents.forEach(intent => {
        let score = 0;
        intent.keywords.forEach(kw => {
          // 1. Exact phrase/word boundary match (Highest weight)
          const exactRegex = new RegExp(`\\b${kw}\\b`, 'i');
          if (exactRegex.test(cleanQuery)) {
            score += kw.length * 2;
          } 
          // 2. Contains match (Lower weight, but helps with plurals or partials)
          else if (cleanQuery.includes(kw)) {
            score += kw.length;
          }
          
          // Bonus for absolute match
          if (cleanQuery === kw) score += 20;
        });

        if (score > bestMatch.score) {
          bestMatch = { key: intent.key, score };
        }
      });

      let response = "";
      if (bestMatch.key === 'default' || !(t as any)[bestMatch.key]) {
        const defaults = Array.isArray(t.default) ? t.default : [t.default];
        response = defaults[Math.floor(Math.random() * defaults.length)];
      } else {
        response = (t as any)[bestMatch.key];
      }

      showResponse(response);
      chatInput.value = '';
    }
  }

  function showResponse(text: string) {
    if (responseText && responseContainer) {
      if (responseTimeout) clearTimeout(responseTimeout);
      responseText.textContent = '';
      responseContainer.classList.remove('hidden');

      let i = 0;
      const typeEffect = setInterval(() => {
        if (i < text.length) {
          responseText.textContent += text.charAt(i);
          i++;
        } else {
          clearInterval(typeEffect);
          responseTimeout = setTimeout(() => {
            responseContainer.classList.add('hidden');
          }, 5000);
        }
      }, 30);
    }
  }

  function updatePlaceholder() {
    const lang = getLang();
    if (chatInput) {
      chatInput.placeholder = languages[lang].chatbot.placeholder;
    }
  }

  document.addEventListener('DOMContentLoaded', updatePlaceholder);
  window.addEventListener('languageChanged', updatePlaceholder);
  chatInput?.addEventListener('keydown', handleChat);
</script>
