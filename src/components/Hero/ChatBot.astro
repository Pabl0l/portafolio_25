---
import { languages, defaultLang, type Language } from '../../i18n';

// Import the image (it will be provided by the user)
// import chatBoxImg from '../../assets/images/cuadro_de_texto.png';
---

<div class="chatbot-container">
  <div class="terminal-input-row">
    <input type="text" id="chat-input" placeholder="..." autocomplete="off" />
  </div>

  <div id="chat-response-container" class="hidden">
    <!-- The user will provide cuadro_de_texto.png -->
    <div class="chat-box">
      <p id="chat-response-text"></p>
    </div>
  </div>
</div>

<style>
  .chatbot-container {
    margin-top: 1.5rem;
    width: 100%;
    font-family: var(--font-terminal);
  }

  .terminal-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid var(--color-matrix-primary);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    box-shadow: 0 0 10px rgba(57, 255, 20, 0.2);
  }

  .prompt {
    color: var(--color-matrix-primary);
    white-space: nowrap;
  }

  #chat-input {
    background: transparent;
    border: none;
    color: #fff;
    font-family: inherit;
    font-size: 1.1rem;
    width: 100%;
    outline: none;
    caret-color: var(--color-matrix-primary);
  }

  /* Response Box - Now positioned relative to the profile column */
  #chat-response-container {
    position: absolute;
    top: 20px; /* Near the top of the image (head level) */
    left: calc(100% + 20px); /* To the right of the image */
    width: 280px;
    z-index: 1000;
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  #chat-response-container.hidden {
    opacity: 0;
    transform: scale(0.8) translateY(20px);
    pointer-events: none;
  }

  .chat-box {
    position: relative;
    padding: 1.5rem;
    background: rgba(13, 13, 13, 0.95);
    border: 2px solid var(--color-matrix-primary);
    border-radius: 12px;
    box-shadow: 0 0 20px rgba(57, 255, 20, 0.4);
    color: var(--color-matrix-primary);
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(5px);
  }

  /* Speech bubble tail (pointing to the image) */
  .chat-box::after {
    content: '';
    position: absolute;
    left: -20px;
    top: 50%;
    transform: translateY(-50%);
    border-width: 10px 20px 10px 0;
    border-style: solid;
    border-color: transparent var(--color-matrix-primary) transparent transparent;
  }

  .chat-box::before {
    content: '';
    position: absolute;
    left: -17px;
    top: 50%;
    transform: translateY(-50%);
    border-width: 9px 18px 9px 0;
    border-style: solid;
    border-color: transparent rgba(13, 13, 13, 0.95) transparent transparent;
    z-index: 1;
  }

  #chat-response-text {
    margin: 0;
    font-size: 1.1rem;
    text-align: center;
    line-height: 1.4;
    text-shadow: 0 0 5px rgba(57, 255, 20, 0.5);
  }

  @media (max-width: 1200px) {
    #chat-response-container {
      left: 50%;
      top: 260px; /* Below the 250px mobile image */
      transform: translateX(-50%);
      width: 100%;
      max-width: 280px;
    }

    #chat-response-container.hidden {
      transform: translateX(-50%) scale(0.8) translateY(-20px);
    }

    .chat-box::after {
      left: 50%;
      top: -20px; /* Pointing UP */
      bottom: auto;
      transform: translateX(-50%);
      border-width: 0 10px 20px 10px;
      border-color: transparent transparent var(--color-matrix-primary) transparent;
    }

    .chat-box::before {
      left: 50%;
      top: -17px;
      bottom: auto;
      transform: translateX(-50%);
      border-width: 0 9px 18px 9px;
      border-color: transparent transparent rgba(13, 13, 13, 0.95) transparent;
    }
  }
</style>

<script>
  import { languages, defaultLang, type Language } from '../../i18n';

  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const responseContainer = document.getElementById('chat-response-container');
  const responseText = document.getElementById('chat-response-text');
  let responseTimeout: any;

  function getLang() {
    return (localStorage.getItem('language') as Language) || defaultLang;
  }

  async function handleChat(e: KeyboardEvent) {
    if (e.key === 'Enter' && chatInput.value.trim()) {
      const query = chatInput.value.toLowerCase().trim();
      const lang = getLang();
      const t = languages[lang].chatbot;
      
      const intents = [
        { key: 'greeting', keywords: ['hola', 'saludo', 'buenas', 'hi', 'hello', 'hey', 'qué tal', 'que tal', 'hablar'] },
        { key: 'whoami', keywords: ['quien', 'quién', 'pablo', 'perfil', 'who', 'eres', 'identidad', 'persona', 'creador'] },
        { key: 'skills', keywords: ['habilidad', 'sabes', 'haces', 'conocimiento', 'skill', 'stack', 'tecnologia', 'programar', 'redes', 'cisco', 'python', 'java', 'js', 'hardware', 'mantenimiento'] },
        { key: 'contact', keywords: ['contacto', 'email', 'correo', 'redes', 'social', 'linkedin', 'github', 'escribir', 'ubicar', 'localizar', 'mensaje'] },
        { key: 'experience', keywords: ['experiencia', 'trabajo', 'mired', 'oficio', 'chamba', 'laboral', 'trayectoria', 'puesto', 'cargo'] },
        { key: 'certifications', keywords: ['certificado', 'cisco', 'ccna', 'estudio', 'educacion', 'título', 'titulo', 'estudió', 'estudio', 'universidad', 'formacion'] },
        { key: 'motto', keywords: ['problema', 'lema', 'motto', 'frase', 'filosofia', 'filosofía', 'guía', 'principio'] },
        { key: 'tools', keywords: ['herramienta', 'navaja', 'tool', 'victorinox', 'arquimedes', 'suiza', 'siempre cargo'] },
        { key: 'music', keywords: ['musica', 'playlist', 'melomano', 'rock', 'metal', 'jazz', 'dance hall', 'electropop', 'sonar', 'cancion'] },
        { key: 'bikes', keywords: ['moto', 'bike', 'rueda', 'libertad', 'conducir', 'rodar', 'motor'] },
        { key: 'hates', keywords: ['odias', 'molesta', 'mal hecho', 'hate', 'rabia', 'disgusto', 'eficiencia'] },
        { key: 'family', keywords: ['familia', 'amigo', 'donde vive', 'casa', 'hogar', 'queridos'] },
        { key: 'status', keywords: ['como estas', 'cómo estás', 'how are you', 'que haces', 'bien o que', 'todo bien', 'tal vas', 'hambre', 'comerte al mundo'] },
        { key: 'movies', keywords: ['pelicula', 'película', 'cine', 'movie', 'film', 'ver', 'don\'t look up', 'dont look up', 'bugonia', 'recomendar'] },
        { key: 'food', keywords: ['comida', 'hambre', 'food', 'hungry', 'essen', 'comer', 'carne', 'papas', 'francesas', 'almuerzo', 'cena'] },
        { key: 'hobbies', keywords: ['hobby', 'pasatiempo', 'ocio', 'lol', 'minecraft', 'isaac', 'juego', 'game', 'ejercicio', 'viajar', 'naturaleza', 'nature', 'color', 'verde', 'entrenar', 'gym', 'silvestre'] },
        { key: 'philosophy', keywords: ['especial', 'aprende', 'puedo', 'capaz', 'special', 'philosophy', 'limitado', 'sabes de todo', 'aprender'] },
        { key: 'goals', keywords: ['meta', 'objetivo', 'futuro', 'goal', 'target', 'aspiracion', 'crecer', 'mejor zapatero', 'llegar'] },
        { key: 'teamwork', keywords: ['equipo', 'horizontal', 'comun', 'team', 'trabajar con otros', 'lider', 'compañero'] },
        { key: 'location', keywords: ['donde eres', 'arauca', 'barranquilla', 'donde estas', 'vivir', 'live', 'base', 'ciudad', 'ubicacion', 'ubicación'] },
        { key: 'failure', keywords: ['fracaso', 'falla', 'error', 'aprendizaje', 'failure', 'equivocarse', 'perder'] },
        { key: 'favTech', keywords: ['python', 'serpiente', 'bota', 'toy story', 'woody'] },
        { key: 'joke', keywords: ['chiste', 'broma', 'gracioso', 'joke', 'reir', 'divertido'] }
      ];

      let bestMatch = { key: 'default', score: 0 };

      // Scoring logic
      intents.forEach(intent => {
        let score = 0;
        intent.keywords.forEach(kw => {
          if (query.includes(kw)) {
            score += 1;
            if (query === kw) score += 2;
          }
        });
        if (score > bestMatch.score) {
          bestMatch = { key: intent.key, score };
        }
      });

      let response = "";
      if (bestMatch.key === 'default' || !(t as any)[bestMatch.key]) {
        const defaults = Array.isArray(t.default) ? t.default : [t.default];
        response = defaults[Math.floor(Math.random() * defaults.length)];
      } else {
        response = (t as any)[bestMatch.key];
      }

      showResponse(response);
      chatInput.value = '';
    }
  }

  function showResponse(text: string) {
    if (responseText && responseContainer) {
      if (responseTimeout) clearTimeout(responseTimeout);
      responseText.textContent = '';
      responseContainer.classList.remove('hidden');

      let i = 0;
      const typeEffect = setInterval(() => {
        if (i < text.length) {
          responseText.textContent += text.charAt(i);
          i++;
        } else {
          clearInterval(typeEffect);
          responseTimeout = setTimeout(() => {
            responseContainer.classList.add('hidden');
          }, 5000);
        }
      }, 30);
    }
  }

  function updatePlaceholder() {
    const lang = getLang();
    if (chatInput) {
      chatInput.placeholder = languages[lang].chatbot.placeholder;
    }
  }

  document.addEventListener('DOMContentLoaded', updatePlaceholder);
  window.addEventListener('languageChanged', updatePlaceholder);
  chatInput?.addEventListener('keydown', handleChat);
</script>
